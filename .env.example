# 雀魂国服网页版入口
MAJSOUL_BASE_URL=https://game.maj-soul.com/1/

# 青龙里建议保持 true，本地调试可改成 false
MAJSOUL_HEADLESS=true

# 直接账号密码登录（可选，不推荐长期依赖）
MAJSOUL_ACCOUNT=
MAJSOUL_PASSWORD=

# 推荐：把本地采集到的 storage state Base64 填到这里
MAJSOUL_STORAGE_STATE_B64=

# 也可以直接让脚本读取本地文件，默认就是 data/maj-soul-storage.json
MAJSOUL_STORAGE_STATE_PATH=

# 本地采集多账号登录态时可选：给当前账号起一个别名
# 例如 main / alt / 小号1
MAJSOUL_ACCOUNT_ALIAS=

# 多账号模式：填写 JSON 数组后，脚本会按顺序逐个处理账号
# 注意每个账号最好使用独立的 storageStatePath 或 storageStateB64
# 示例：
# MAJSOUL_MULTI_ACCOUNTS_JSON=[{"name":"main","storageStatePath":"data/maj-soul-storage-main.json"},{"name":"alt","storageStatePath":"data/maj-soul-storage-alt.json"}]
MAJSOUL_MULTI_ACCOUNTS_JSON=

# 多账号模式下，某个账号失败后是否继续执行后续账号
MAJSOUL_CONTINUE_ON_ERROR=true

# 页面总超时，单位毫秒
MAJSOUL_TIMEOUT_MS=120000

# 首屏打开后的额外等待，给首页资源和登录入口加载时间
MAJSOUL_INITIAL_LOAD_WAIT_MS=20000

# 点击“开始游戏/进入游戏”后的额外等待，给登录页加载时间
MAJSOUL_AFTER_START_WAIT_MS=15000

# 提交登录或恢复登录态后，等待进入大厅/自动到账
MAJSOUL_POST_LOGIN_WAIT_MS=50000

# 关闭首屏弹窗后再额外等一会儿，避免大厅继续补资源
MAJSOUL_FINAL_STABILIZE_WAIT_MS=8000
