# ql_scripts 环境变量示例
# 当前仓库已实现雀魂与 Poi6 论坛脚本，后续新增站点时再按站点前缀扩展。

# ==============================
# 雀魂（Majsoul）脚本配置
# ==============================

# 雀魂国服网页版入口
MAJSOUL_BASE_URL=https://game.maj-soul.com/1/

# 青龙里建议保持 true，本地调试可改成 false
MAJSOUL_HEADLESS=true

# 推荐：把本地采集到的 storage state Base64 填到这里
MAJSOUL_STORAGE_STATE_B64=

# 也可以直接让脚本读取本地文件，默认就是 data/majsoul/maj-soul-storage.json
MAJSOUL_STORAGE_STATE_PATH=

# 本地采集多账号登录态时可选：给当前账号起一个别名
# 例如 main / alt / 小号1
MAJSOUL_ACCOUNT_ALIAS=

# 多账号模式：填写 JSON 数组后，脚本会按顺序逐个处理账号
# 注意每个账号最好使用独立的 storageStatePath 或 storageStateB64
# 示例：
# MAJSOUL_MULTI_ACCOUNTS_JSON=[{"name":"main","storageStatePath":"data/majsoul/maj-soul-storage-main.json"},{"name":"alt","storageStatePath":"data/majsoul/maj-soul-storage-alt.json"}]
MAJSOUL_MULTI_ACCOUNTS_JSON=

# 多账号模式下，某个账号失败后是否继续执行后续账号
MAJSOUL_CONTINUE_ON_ERROR=true

# 页面打开超时，单位毫秒
MAJSOUL_TIMEOUT_MS=120000

# 固定等待时间：用于给雀魂从恢复登录态到进入大厅的完整读条过程留足时间
# 建议从 180000 到 300000 之间调参，默认 300000
MAJSOUL_HALL_WAIT_MS=300000

# 可选：Bark 推送地址，通常形如 https://api.day.app/<你的key>/push
MAJSOUL_BARK_PUSH_URL=

# 可选：若你希望 Bark 里直接带图，需要给 screenshots/majsoul/ 提供公网静态访问基址
# 例如 https://example.com/majsoul-screenshots
# 未配置时，Bark 只会发送文字通知和本地截图路径
MAJSOUL_BARK_SCREENSHOT_BASE_URL=

# 可选：Bark 分组名
MAJSOUL_BARK_GROUP=majsoul

# ==============================
# Poi6 论坛脚本配置
# ==============================

# Poi6 论坛入口
POI6_BASE_URL=https://poi6.net/

# 青龙里建议保持 true，本地调试可改成 false
POI6_HEADLESS=true

# Poi6 账号密码自动登录（可选；若已提供 storage state，可不填）
POI6_EMAIL=
POI6_PASSWORD=

# 是否勾选“保持登入”
POI6_REMEMBER_LOGIN=true

# 推荐：把本地采集到的 storage state Base64 填到这里
POI6_STORAGE_STATE_B64=

# 也可以直接让脚本读取本地文件，默认就是 data/poi6/poi6-storage.json
POI6_STORAGE_STATE_PATH=

# 本地采集多账号登录态时可选：给当前账号起一个别名
POI6_ACCOUNT_ALIAS=

# 多账号模式：填写 JSON 数组后，脚本会按顺序逐个处理账号
# 每个账号可独立配置 email/password 或 storageStatePath/storageStateB64
# 示例：
# POI6_MULTI_ACCOUNTS_JSON=[{"name":"main","email":"main@example.com","password":"123456"},{"name":"alt","storageStatePath":"data/poi6/poi6-storage-alt.json"}]
POI6_MULTI_ACCOUNTS_JSON=

# 多账号模式下，某个账号失败后是否继续执行后续账号
POI6_CONTINUE_ON_ERROR=true

# 页面打开超时，单位毫秒
POI6_TIMEOUT_MS=120000

# 固定在线时长：Poi6 每日在线 5 分钟可自动签到获取积分
POI6_ONLINE_WAIT_MS=300000

# 可选：Bark 推送地址，通常形如 https://api.day.app/<你的key>/push
POI6_BARK_PUSH_URL=

# 可选：若你希望 Bark 里直接带图，需要给 screenshots/poi6/ 提供公网静态访问基址
# 例如 https://example.com/poi6-screenshots
# 未配置时，Bark 只会发送文字通知和本地截图路径
POI6_BARK_SCREENSHOT_BASE_URL=

# 可选：Bark 分组名
POI6_BARK_GROUP=poi6
